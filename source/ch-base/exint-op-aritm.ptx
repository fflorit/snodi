<?xml version='1.0' encoding='utf-8'?>

<subsection xml:id="exint-op-aritm" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Esercizi sulle operazioni base</title>
    <p>
        Il seguente esercizio interattivo ti permette di verificare le tue abilità di calcolo con le frazioni per le operazioni elementari di somma, sottrazione, moltiplicazione e divisione.
    </p>
    <exercise>
        <title>&#x2728; Operazioni elementari tra numeri razionali</title>
        <webwork>
            <pg-code>
                loadMacros(
                "PGstandard.pl",
                "MathObjects.pl",
                "PGML.pl",
                "PGcourse.pl"
                );

                Context("Fraction");

                $n1 = random(1, 19, 1);
                $d1 = list_random(2,3,4,5,6,7,8,9,10,12,14,15,16);
                $n2 = random(1, 19, 1);
                $d2 = list_random(2,3,4,5,6,7,8,9,10,12,14,15,16);
                $F1 = Fraction($n1, $d1);
                $F2 = Fraction($n2, $d2);
                
                $somma = $F1 + $F2;
                $differenza = $F1 - $F2;
                $prodotto = $F1*$F2;
                $quoziente = $F1/$F2;
            </pg-code>

            <statement>
                <p>
                    Determina somma, differenza, prodotto e quoziente dei due numeri razionali <m>[$F1]</m> e <m>[$F2]</m>.
                </p>
                <p>
                    Somma: <m>[$F1]+[$F2]=</m> <var name="$somma" width="10"/>
                </p>
                <p>
                    Differenza: <m>[$F1]-[$F2]=</m> <var name="$differenza" width="10"/>
                </p>
                <p>
                    Prodotto: <m>[$F1]\cdot[$F2]=</m> <var name="$prodotto" width="10"/>
                </p>
                <p>
                    Quoziente: <m>\dfrac{[$F1]}{[$F2]}=</m> <var name="$quoziente" width="10"/>
                </p>
            </statement>

            <!-- <solution>
                <p>
                    Somma <m>[$somma]</m>, differenza <m>[$differenza]</m>, prodotto <m>[$prodotto]</m>, quoziente <m>[$quoziente]</m>.
                </p>
            </solution> -->
        </webwork>
    </exercise>

</subsection>