  <section xml:id="sec-retta_interattiva">
	<title>Esempio interattivo</title>
		<!-- From the sample article -->
		<figure>
			<caption>Effetto di <m>m</m> e <m>q</m> sul grafico di una retta.</caption>
			<interactive xml:id="interactive-retta" platform="jsxgraph" width="60%"
			source="jsxgraph/retta.js">
			<slate xml:id="jsxgraph-retta" surface="jsxboard" />
			<instructions>
			<p>Trascina gli slider per modificare l'inclinazione e l'intercetta della retta.</p>
			</instructions>
			</interactive>
		</figure>
	</section>

